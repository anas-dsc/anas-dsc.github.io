---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal';
import CvSubNav from '~/components/CvSubNav.astro';
import Timeline from '~/components/Timeline.astro';
import { education } from '~/data/cv';

const items = education.map((e) => ({
  period: e.period,
  title: e.school,
  subtitle: e.degree,
  detail: e.detail,
}));
---

<Base title="Education">
  <section class="max-w-4xl mx-auto px-6 py-24">
    <Reveal client:load>
      <p class="text-xs uppercase tracking-[0.3em] text-white/60 mb-3">CV · Education</p>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold">🎓 Education</h1>
    </Reveal>

    <div class="mt-12">
      <CvSubNav />
    </div>

    <Reveal client:load delay={0.05}>
      <Timeline items={items} />
    </Reveal>
  </section>
</Base>
