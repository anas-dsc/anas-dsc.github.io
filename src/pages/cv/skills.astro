---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal';
import CvSubNav from '~/components/CvSubNav.astro';
import SkillBadge from '~/components/SkillBadge.astro';
import { skills } from '~/data/cv';
import { getRecentlyLearnedSkills } from '~/lib/skills';

const recentlyLearned = await getRecentlyLearnedSkills();
---

<Base title="Skills">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <Reveal client:load>
      <p class="text-xs uppercase tracking-[0.3em] text-white/60 mb-3">CV · Skills</p>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold">🛠 Skills</h1>
    </Reveal>

    <div class="mt-12">
      <CvSubNav />
    </div>

    <div class="space-y-6">
      {skills.map((s, i) => (
        <Reveal client:load delay={i * 0.05}>
          <div class="card p-6">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-4">{s.group}</p>
            <div class="flex flex-wrap gap-2.5">
              {s.items.map((item) => <SkillBadge skill={item} />)}
            </div>
          </div>
        </Reveal>
      ))}

      {recentlyLearned.length > 0 && (
        <Reveal client:load delay={skills.length * 0.05}>
          <div class="card p-6">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-2">Recently Learned</p>
            <p class="text-xs text-[var(--color-muted)] mb-4 opacity-70">Picked up while building — sourced from project topics</p>
            <div class="flex flex-wrap gap-2.5">
              {recentlyLearned.map((name) => <SkillBadge skill={{ name }} />)}
            </div>
          </div>
        </Reveal>
      )}
    </div>
  </section>
</Base>
