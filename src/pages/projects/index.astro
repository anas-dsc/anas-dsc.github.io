---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal';
import ProjectFilter from '~/components/ProjectFilter';
import type { ProjectItem } from '~/components/ProjectFilter';
import { getAllProjects } from '~/lib/projects';

const all = await getAllProjects();
const projects: ProjectItem[] = all.map((p) => ({
  slug: p.slug,
  title: p.title,
  description: p.description,
  tags: p.tags,
}));
---

<Base title="Projects">
  <section class="max-w-6xl mx-auto px-6 py-24">
    <Reveal client:load>
      <p class="text-xs uppercase tracking-[0.3em] text-white/60 mb-3">Projects</p>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold">Things I've built.</h1>
    </Reveal>

    <div class="mt-12">
      <ProjectFilter client:load projects={projects} />
    </div>
  </section>
</Base>
