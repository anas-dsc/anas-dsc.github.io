---
import Base from '~/layouts/Base.astro';
import Reveal from '~/components/Reveal';
import CvSubNav from '~/components/CvSubNav.astro';
import { experience, education, skills, societies, interests } from '~/data/cv';

const cards = [
  {
    href: '/cv/experience/',
    title: 'Experience',
    icon: '💼',
    summary: 'Software Developer · Data & AI Engineer · IT Administrator',
  },
  {
    href: '/cv/education/',
    title: 'Education',
    icon: '🎓',
    summary: `${education.length} degrees · TU Berlin & FU Berlin.`,
  },
  {
    href: '/cv/skills/',
    title: 'Skills',
    icon: '🛠',
    summary: `${skills.length} groups · ${skills.reduce((n, g) => n + g.items.length, 0)} skills.`,
  },
  {
    href: '/cv/societies/',
    title: 'Societies & Interests',
    icon: '🌐',
    summary: `${societies.length} memberships · ${interests.length} interests.`,
  },
];
---

<Base title="CV">
  <section class="max-w-5xl mx-auto px-6 py-24">
    <Reveal client:load>
      <p class="text-xs uppercase tracking-[0.3em] text-white/60 mb-3">Curriculum Vitae</p>
      <h1 class="font-[var(--font-display)] text-4xl md:text-5xl font-semibold">CV</h1>
      <p class="mt-4 text-lg text-white/75 max-w-2xl">
        A snapshot of my work, studies, skills, and the things I do beyond the screen.
      </p>
    </Reveal>

    <div class="mt-12">
      <CvSubNav />
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {cards.map((c, i) => (
        <Reveal client:load delay={i * 0.06}>
          <a href={c.href} class="card block p-7 h-full">
            <div class="text-3xl mb-3">{c.icon}</div>
            <h2 class="font-[var(--font-display)] text-2xl font-semibold mb-1">{c.title}</h2>
            <p class="text-sm text-[var(--color-muted)]">{c.summary}</p>
            <span class="text-sm text-[var(--color-accent-2)] mt-4 inline-block">Open →</span>
          </a>
        </Reveal>
      ))}
    </div>
  </section>
</Base>
