---
interface TimelineItem {
  period: string;
  title: string;
  subtitle?: string;
  detail?: string;
  bullets?: string[];
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="relative border-l border-[var(--color-border)] ml-3 space-y-10">
  {items.map((item) => (
    <li class="relative pl-8">
      <span
        class="absolute -left-[7px] top-1 w-3.5 h-3.5 rounded-full bg-[var(--color-accent)] ring-4 ring-[var(--color-bg)]"
        style="box-shadow: 0 0 16px rgba(124, 92, 255, 0.7);"
      ></span>
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-muted)] mb-2">{item.period}</p>
      <div class="card p-6">
        <h3 class="font-semibold text-white">{item.title}</h3>
        {item.subtitle && (
          <p class="text-sm text-[var(--color-accent-2)] mt-1">{item.subtitle}</p>
        )}
        {item.detail && (
          <p class="text-sm text-[color:var(--color-fg)]/80 mt-3">{item.detail}</p>
        )}
        {item.bullets && item.bullets.length > 0 && (
          <ul class="list-disc list-inside text-sm text-[color:var(--color-fg)]/80 space-y-1 mt-3">
            {item.bullets.map((b) => <li>{b}</li>)}
          </ul>
        )}
      </div>
    </li>
  ))}
</ol>
