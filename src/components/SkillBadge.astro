---
import type { Skill } from '~/data/cv';

interface Props {
  skill: Skill;
}

const { skill } = Astro.props;
const iconUrl = skill.icon ? `https://cdn.simpleicons.org/${skill.icon}/white` : null;
---

<div class="group flex items-center gap-2.5 px-3 py-2 rounded-xl bg-white/[0.04] border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:bg-white/[0.07] transition-all">
  {iconUrl ? (
    <img
      src={iconUrl}
      alt=""
      width="18"
      height="18"
      loading="lazy"
      class="w-[18px] h-[18px] opacity-80 group-hover:opacity-100 transition-opacity"
    />
  ) : skill.emoji ? (
    <span class="text-base leading-none w-[18px] text-center" aria-hidden="true">{skill.emoji}</span>
  ) : (
    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
  )}
  <span class="text-sm text-white/90 group-hover:text-white">{skill.name}</span>
</div>
